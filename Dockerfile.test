# Pinned by SHA digest to satisfy OpenSSF Scorecard's Pinned-Dependencies check
# (PinnedDependenciesID: containerImage not pinned by hash). See Dockerfile for
# the rationale and Dependabot strategy; see .github/scorecard-pinned-deps.md
# for the full coverage matrix.
FROM python:3.14-slim@sha256:c845af9399020c7e562969a13689e929074a10fd057acd1b1fad06a2fb068e97

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# Copy project files
COPY . .

# Install package with test and blockchain dependencies
RUN pip install --no-cache-dir -e ".[test,blockchain]"

# Default: run full test suite
CMD ["python", "-m", "pytest", "tests/", "-v", "--tb=short", "-m", "not live_blockchain", "--color=yes"]
